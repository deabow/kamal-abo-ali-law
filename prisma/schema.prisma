generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Consultation {
  id        String             @id @default(cuid())
  name      String             @db.VarChar(120)
  phone     String             @db.VarChar(30)
  category  ConsultationCategory
  date      DateTime
  status    ConsultationStatus @default(PENDING)
  notes     String?            @db.VarChar(500)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([status, date])
  @@index([createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  fullName     String   @db.VarChar(120)
  email        String   @unique @db.VarChar(190)
  passwordHash String   @db.VarChar(255)
  role         String   @default("admin") @db.VarChar(30)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(120)
  email     String?  @db.VarChar(190)
  phone     String?  @db.VarChar(30)
  subject   String?  @db.VarChar(160)
  message   String   @db.VarChar(4000)
  status    String   @default("NEW") @db.VarChar(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

enum ConsultationCategory {
  FAMILY
  CRIMINAL
  CIVIL
  CORPORATE
  LABOR
  REAL_ESTATE
  OTHER
}

enum ConsultationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
